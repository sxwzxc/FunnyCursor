<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MouseBeautifier.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FunnyCursor 设置">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="28,20,28,20"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                MaxWidth="720"
                HorizontalAlignment="Center"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="50"
                    Height="50"
                    VerticalAlignment="Center"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="14">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Text="FC" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="FunnyCursor" />
                    <TextBlock Opacity="0.68" FontSize="13" Text="鼠标美化与悬挂物理设置" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Click="ExitButton_Click"
                    Content="退出程序" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel
                MaxWidth="720"
                HorizontalAlignment="Center"
                Padding="28,20,28,28"
                Spacing="12">
                <Expander Header="点击特效" IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableClickEffectsToggle"
                            Header="启用点击特效"
                            Toggled="SettingChanged" />
                        <ComboBox
                            x:Name="ClickPresetCombo"
                            Header="特效预设"
                            SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="闪烁粒子" Tag="sparkle" />
                            <ComboBoxItem Content="彩色纸屑" Tag="confetti" />
                            <ComboBoxItem Content="扩散光环" Tag="ring" />
                            <ComboBoxItem Content="水波纹" Tag="ripple" />
                        </ComboBox>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ClickColorText"
                                Header="特效颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="ClickColorPicker"
                                            Tag="ClickColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="ClickParticleCountSlider"
                            Header="粒子数量"
                            Maximum="200"
                            Minimum="1"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="ClickSpeedSlider"
                            Header="喷射速度"
                            Maximum="2000"
                            Minimum="50"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="ClickGravitySlider"
                            Header="重力"
                            Maximum="3000"
                            Minimum="0"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander Header="悬挂绳子与图标" IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableRopeToggle"
                            Header="启用悬挂绳子"
                            Toggled="SettingChanged" />
                        <Slider
                            x:Name="RopeLengthSlider"
                            Header="绳子长度"
                            Maximum="500"
                            Minimum="20"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeSegmentsSlider"
                            Header="绳子节数"
                            Maximum="40"
                            Minimum="2"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeGravitySlider"
                            Header="绳子重力"
                            Maximum="3000"
                            Minimum="0"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeDampingSlider"
                            Header="阻尼"
                            Maximum="0.99"
                            Minimum="0.5"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeStiffnessSlider"
                            Header="刚度"
                            Maximum="1"
                            Minimum="0.1"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeWidthSlider"
                            Header="绳子粗细"
                            Maximum="20"
                            Minimum="1"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <ComboBox
                            x:Name="IconTypeCombo"
                            Header="悬挂图标"
                            SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="五角星" Tag="star" />
                            <ComboBoxItem Content="圆形" Tag="circle" />
                            <ComboBoxItem Content="方形" Tag="square" />
                            <ComboBoxItem Content="三角" Tag="triangle" />
                            <ComboBoxItem Content="菱形" Tag="diamond" />
                            <ComboBoxItem Content="心形" Tag="heart" />
                            <ComboBoxItem Content="笑脸" Tag="smiley" />
                            <ComboBoxItem Content="粉色小猪" Tag="pig" />
                            <ComboBoxItem Content="二次元女孩" Tag="girl" />
                            <ComboBoxItem Content="自定义图片" Tag="custom" />
                        </ComboBox>
                        <Slider
                            x:Name="IconSizeSlider"
                            Header="图标大小"
                            Maximum="120"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="IconColorText"
                                Header="图标颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="IconColorPicker"
                                            Tag="IconColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="RopeColorText"
                                Header="绳子颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="RopeColorPicker"
                                            Tag="RopeColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="CustomIconPathText"
                                Header="自定义图标路径"
                                LostFocus="SettingChanged" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="BrowseIconButton_Click"
                                Content="浏览…" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Header="光标拖尾">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableTrailToggle"
                            Header="启用拖尾"
                            Toggled="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="TrailColorText"
                                Header="拖尾颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="TrailColorPicker"
                                            Tag="TrailColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="TrailLengthSlider"
                            Header="拖尾长度（秒）"
                            Maximum="2"
                            Minimum="0.1"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="TrailWidthSlider"
                            Header="拖尾宽度"
                            Maximum="40"
                            Minimum="2"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander Header="环绕粒子">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableOrbitToggle"
                            Header="启用环绕粒子"
                            Toggled="SettingChanged" />
                        <Slider
                            x:Name="OrbitCountSlider"
                            Header="粒子数量"
                            Maximum="60"
                            Minimum="1"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitRadiusSlider"
                            Header="环绕半径"
                            Maximum="200"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitSpeedSlider"
                            Header="旋转速度（度/秒）"
                            Maximum="360"
                            Minimum="-360"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitSizeSlider"
                            Header="粒子大小"
                            Maximum="40"
                            Minimum="2"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="OrbitColorText"
                                Header="粒子颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="OrbitColorPicker"
                                            Tag="OrbitColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander Header="光标光晕">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableGlowToggle"
                            Header="启用光晕"
                            Toggled="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="GlowColorText"
                                Header="光晕颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="GlowColorPicker"
                                            Tag="GlowColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="GlowSizeSlider"
                            Header="光晕半径"
                            Maximum="200"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="GlowIntensitySlider"
                            Header="光晕强度"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander Header="常规与关于">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="StartWithWindowsToggle"
                            Header="开机自启"
                            Toggled="SettingChanged" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Click="ResetButton_Click" Content="恢复默认设置" />
                            <Button Click="CopyVersionButton_Click" Content="复制版本号" />
                            <Button Click="OpenRepositoryButton_Click" Content="打开项目仓库" />
                        </StackPanel>
                        <TextBlock x:Name="ProductText" FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionText" />
                        <TextBlock x:Name="AuthorText" />
                        <TextBlock x:Name="CopyrightText" TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
