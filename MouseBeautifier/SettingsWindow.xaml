<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MouseBeautifier.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FunnyCursor 设置">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="32,20,32,20"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid
                HorizontalAlignment="Stretch"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="50"
                    Height="50"
                    VerticalAlignment="Center"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="14">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                        Text="FC" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="FunnyCursor" />
                    <TextBlock Opacity="0.68" FontSize="13" Text="鼠标美化与悬挂物理设置" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Click="ExitButton_Click"
                    Content="退出程序" />
            </Grid>
        </Border>

        <NavigationView
            x:Name="SettingsNavigation"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            PaneDisplayMode="Left"
            SelectionChanged="SettingsNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="点击特效" Tag="ClickEffects" />
                <NavigationViewItem Content="悬挂绳子与图标" Tag="Rope" />
                <NavigationViewItem Content="光标拖尾" Tag="Trail" />
                <NavigationViewItem Content="星云环绕" Tag="Orbit" />
                <NavigationViewItem Content="光标光晕" Tag="Glow" />
                <NavigationViewItem Content="常规与关于" Tag="General" />
            </NavigationView.MenuItems>
            <NavigationView.Content>
                <ScrollViewer
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel
                        HorizontalAlignment="Stretch"
                        Padding="28,24,32,36"
                        Spacing="14">
                <Expander
                    x:Name="ClickEffectsSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="点击特效"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableClickEffectsToggle"
                            Header="启用点击特效"
                            Toggled="SettingChanged" />
                        <ComboBox
                            x:Name="ClickPresetCombo"
                            Header="特效预设"
                            SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="闪烁粒子" Tag="sparkle" />
                            <ComboBoxItem Content="彩色纸屑" Tag="confetti" />
                            <ComboBoxItem Content="扩散光环" Tag="ring" />
                            <ComboBoxItem Content="水波纹" Tag="ripple" />
                        </ComboBox>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ClickColorText"
                                Header="特效颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="ClickColorPicker"
                                            Tag="ClickColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="ClickParticleCountSlider"
                            Header="粒子数量"
                            Maximum="200"
                            Minimum="1"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="ClickSpeedSlider"
                            Header="喷射速度"
                            Maximum="2000"
                            Minimum="50"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="ClickGravitySlider"
                            Header="重力"
                            Maximum="3000"
                            Minimum="0"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander
                    x:Name="RopeSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="悬挂绳子与图标"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableRopeToggle"
                            Header="启用悬挂绳子"
                            Toggled="SettingChanged" />
                        <Slider
                            x:Name="RopeLengthSlider"
                            Header="绳子长度"
                            Maximum="500"
                            Minimum="20"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeSegmentsSlider"
                            Header="绳子节数"
                            Maximum="40"
                            Minimum="2"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeGravitySlider"
                            Header="绳子重力"
                            Maximum="3000"
                            Minimum="0"
                            StepFrequency="10"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeDampingSlider"
                            Header="阻尼"
                            Maximum="0.99"
                            Minimum="0.5"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeStiffnessSlider"
                            Header="刚度"
                            Maximum="1"
                            Minimum="0.1"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="RopeWidthSlider"
                            Header="绳子粗细"
                            Maximum="20"
                            Minimum="1"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <ComboBox
                            x:Name="RopeStyleCombo"
                            Header="绳子样式"
                            SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="霓虹线缆" Tag="neon" />
                            <ComboBoxItem Content="玻璃光纤" Tag="glass" />
                            <ComboBoxItem Content="极简细线" Tag="minimal" />
                            <ComboBoxItem Content="脉冲光带" Tag="pulse" />
                        </ComboBox>
                        <ComboBox
                            x:Name="IconTypeCombo"
                            Header="悬挂图标"
                            SelectionChanged="SettingChanged">
                            <ComboBoxItem Content="五角星" Tag="star" />
                            <ComboBoxItem Content="圆形" Tag="circle" />
                            <ComboBoxItem Content="方形" Tag="square" />
                            <ComboBoxItem Content="三角" Tag="triangle" />
                            <ComboBoxItem Content="菱形" Tag="diamond" />
                            <ComboBoxItem Content="心形" Tag="heart" />
                            <ComboBoxItem Content="笑脸" Tag="smiley" />
                            <ComboBoxItem Content="粉色小猪" Tag="pig" />
                            <ComboBoxItem Content="二次元女孩" Tag="girl" />
                            <ComboBoxItem Content="自定义图片" Tag="custom" />
                        </ComboBox>
                        <Slider
                            x:Name="IconSizeSlider"
                            Header="图标大小"
                            Maximum="120"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="IconColorText"
                                Header="图标颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="IconColorPicker"
                                            Tag="IconColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="RopeColorText"
                                Header="绳子颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="RopeColorPicker"
                                            Tag="RopeColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="CustomIconPathText"
                                Header="自定义图标路径"
                                LostFocus="SettingChanged" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Click="BrowseIconButton_Click"
                                Content="浏览…" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander
                    x:Name="TrailSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="光标拖尾"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableTrailToggle"
                            Header="启用拖尾"
                            Toggled="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="TrailColorText"
                                Header="拖尾颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="TrailColorPicker"
                                            Tag="TrailColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="TrailLengthSlider"
                            Header="拖尾长度（秒）"
                            Maximum="2"
                            Minimum="0.1"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="TrailWidthSlider"
                            Header="拖尾宽度"
                            Maximum="40"
                            Minimum="2"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander
                    x:Name="OrbitSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="星云环绕"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <TextBlock
                            Opacity="0.68"
                            Text="炫彩星尘、彗星尾迹与多层光雾以不同轨道围绕光标流动。"
                            TextWrapping="Wrap" />
                        <ToggleSwitch
                            x:Name="EnableOrbitToggle"
                            Header="启用星云环绕"
                            Toggled="SettingChanged" />
                        <Slider
                            x:Name="OrbitCountSlider"
                            Header="星尘密度"
                            Maximum="120"
                            Minimum="12"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitRadiusSlider"
                            Header="星云范围"
                            Maximum="260"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitSpeedSlider"
                            Header="旋转速度（度/秒）"
                            Maximum="360"
                            Minimum="-360"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitSizeSlider"
                            Header="发光粒子大小"
                            Maximum="12"
                            Minimum="0.5"
                            StepFrequency="0.25"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="OrbitStrokeWidthSlider"
                            Header="粒子描边宽度"
                            Maximum="8"
                            Minimum="0"
                            StepFrequency="0.1"
                            ValueChanged="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="OrbitColorText"
                                Header="星云主色调（自动混合多种颜色）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="OrbitColorPicker"
                                            Tag="OrbitColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Expander>

                <Expander
                    x:Name="GlowSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="光标光晕"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="EnableGlowToggle"
                            Header="启用光晕"
                            Toggled="SettingChanged" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="GlowColorText"
                                Header="光晕颜色（#AARRGGBB）"
                                LostFocus="SettingChanged" />
                            <Button Grid.Column="1" VerticalAlignment="Bottom" Content="选择颜色">
                                <Button.Flyout>
                                    <Flyout>
                                        <ColorPicker
                                            x:Name="GlowColorPicker"
                                            Tag="GlowColor"
                                            ColorChanged="ColorPicker_ColorChanged"
                                            IsAlphaEnabled="True"
                                            IsColorChannelTextInputVisible="True" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                        <Slider
                            x:Name="GlowSizeSlider"
                            Header="光晕半径"
                            Maximum="200"
                            Minimum="10"
                            StepFrequency="1"
                            ValueChanged="SettingChanged" />
                        <Slider
                            x:Name="GlowIntensitySlider"
                            Header="光晕强度"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.01"
                            ValueChanged="SettingChanged" />
                    </StackPanel>
                </Expander>

                <Expander
                    x:Name="GeneralSection"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Header="常规与关于"
                    IsExpanded="True">
                    <StackPanel Padding="0,12,0,4" Spacing="12">
                        <ToggleSwitch
                            x:Name="StartWithWindowsToggle"
                            Header="开机自启"
                            Toggled="SettingChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                HorizontalAlignment="Stretch"
                                Click="ResetButton_Click"
                                Content="恢复默认设置" />
                            <Button
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Click="CopyVersionButton_Click"
                                Content="复制版本号" />
                            <Button
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Click="OpenRepositoryButton_Click"
                                Content="打开项目仓库" />
                        </Grid>
                        <TextBlock x:Name="ProductText" FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionText" />
                        <TextBlock x:Name="AuthorText" />
                        <TextBlock x:Name="CopyrightText" TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>
                    </StackPanel>
                </ScrollViewer>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>
